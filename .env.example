# Sage configuration

# Myelin / NATS broker
NATS_URL=nats://localhost:4222
NATS_CREDS_FILE=~/.config/nats/creds/sage.creds

# Sage identity
SAGE_AGENT_ID=sage
SAGE_DID=did:mf:sage
SAGE_SOURCE=metafactory.sage.local
SAGE_ORG=metafactory
SAGE_DATA_RESIDENCY=CH

# Substrate selection — pi (default) or claude. Falls back to
# sage.config.json → substrate.default → pi.
# SAGE_SUBSTRATE=pi

# pi.dev substrate — Sage shells out to `pi -p`. Default provider is
# `google` (Gemini); switch to anthropic / openrouter / openai / … by
# changing PI_PROVIDER. `pi --help` lists every provider pi knows.
PI_BIN=pi
PI_PROVIDER=anthropic
PI_MODEL=anthropic/claude-sonnet-4-6

# Claude Code substrate — only used when SAGE_SUBSTRATE=claude
# CLAUDE_BIN=claude
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_PERMISSION_MODE=acceptEdits

# Provider API keys — auto-forwarded to the substrate subprocess by
# buildSubstrateEnv(). Set only the ones you actually use. Variable
# names track what `pi --help` documents so an operator who exports
# the key pi reads doesn't need a SAGE_ENV_ALLOW override.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Gemini (pi.dev's `google` provider). pi reads GEMINI_API_KEY by
# default; the GOOGLE_* aliases are forwarded too in case the operator
# uses a different ecosystem's naming convention.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=
CEREBRAS_API_KEY=

# Azure / AWS Bedrock — uncomment if used
# AZURE_OPENAI_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_REGION=

# Extend or restrict the forwarding allow-list:
#   SAGE_ENV_ALLOW=MY_CUSTOM_KEY,ANOTHER_KEY    # comma-separated, appended
#   SAGE_ENV_DENY=OPENAI_API_KEY                # comma-separated, stripped
# Legacy PI_ENV_ALLOW / PI_ENV_DENY are still honored for back-compat.
# Note: keys starting with PI_ / CLAUDE_ are forwarded only to the matching
# substrate (namespace isolation).

# GitHub (uses `gh` CLI auth by default — no token needed if `gh auth status` is green)
GH_BIN=gh
