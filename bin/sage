#!/usr/bin/env bash
# sage launcher — resolves the install root and dispatches to the CLI.
#
# When arc installs sage, it symlinks ~/bin/sage to this script inside
# ~/.config/metafactory/pkg/repos/sage/bin/sage. The launcher must find
# the repo root regardless of how it was invoked.

set -euo pipefail

# Resolve symlinks to find the real script directory.
SCRIPT="$0"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
  SCRIPT="$(readlink "$SCRIPT")"
  [[ "$SCRIPT" != /* ]] && SCRIPT="$DIR/$SCRIPT"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"
REPO_ROOT="$(cd -P "$SCRIPT_DIR/.." && pwd)"

if ! command -v bun >/dev/null 2>&1; then
  echo "sage: 'bun' not on PATH — install from https://bun.sh" >&2
  exit 1
fi

# Load env from ~/.config/sage/.env if present. This is where operators
# put provider API keys (OPENROUTER_API_KEY, ANTHROPIC_API_KEY, etc.) for
# the launchd-managed daemon — launchd does NOT read shell init files, so
# without this load step the daemon's env is empty of secrets even when
# the operator's terminal session has them set. chmod 600 recommended.
SAGE_ENV_FILE="${HOME}/.config/sage/.env"
if [[ -f "$SAGE_ENV_FILE" ]]; then
  if [[ "$(stat -f '%Mp%Lp' "$SAGE_ENV_FILE" 2>/dev/null)" =~ [4567]$ ]]; then
    echo "sage: warning — $SAGE_ENV_FILE is world/group-readable (chmod 600 recommended)" >&2
  fi
  set -a
  # shellcheck disable=SC1090
  source "$SAGE_ENV_FILE"
  set +a
fi

exec bun run "$REPO_ROOT/src/cli/index.ts" "$@"
